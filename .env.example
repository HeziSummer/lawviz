# LawViz private/internal MVP environment template.
# Copy to .env for local development. Do not commit real production secrets.

APP_ENV=local
APP_NAME=LawViz

# Local PostgreSQL defaults used by docker-compose.yml.
POSTGRES_DB=lawviz
POSTGRES_USER=lawviz
POSTGRES_PASSWORD=lawviz_local_dev_password
DATABASE_URL=postgresql+psycopg://lawviz:lawviz_local_dev_password@127.0.0.1:5433/lawviz

# Auth. Replace locally; never commit a real production value.
JWT_SECRET=replace-with-local-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Feature gates for private/internal MVP.
ENABLE_PUBLIC_SIGNUP=false
ENABLE_PUBLIC_SHARE=false
ENABLE_LIVE_PAYMENT=false
ENABLE_PKULAW=false
ENABLE_CLOUD_STORAGE=false

# Optional model gateway. Leave empty for local/private adapter mode.
NEW_API_BASE_URL=
NEW_API_KEY=
NEW_API_DEFAULT_MODEL=
NEW_API_CLAUDE_MODEL=

# Optional Pkulaw MCP. Leave empty unless access is configured.
PKULAW_MCP_URL=
PKULAW_MCP_TOKEN=

# Optional object storage. Leave empty for local storage adapter mode.
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./storage
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# Optional Hupijiao adapter. Live payment must stay disabled until approved.
HUPIJIAO_PID=
HUPIJIAO_SECRET=
HUPIJIAO_NOTIFY_URL=
