{
    "id":  "lawviz-editorial-ink",
    "name":  "LawViz Editorial Ink",
    "version":  "0.1.0",
    "status":  "sample-pack",
    "purpose":  "A4 portrait editorial e-ink style pack for LawViz reports. It defines page shell, tokens, components, identity rendering, and renderer constraints without binding to any case type.",
    "sources":  [
                    {
                        "name":  "Guizang Editorial E-Ink Deck",
                        "plugin_url":  "https://open-design.ai/",
                        "example_url":  "https://open-design.ai/",
                        "github_url":  "",
                        "role":  "Primary editorial e-ink typography, high-contrast page rhythm, monochrome deck feel"
                    }
                ],
    "visual_tokens":  {
                          "page":  {
                                       "format":  "A4 portrait",
                                       "screen_preview_px":  {
                                                                 "width":  794,
                                                                 "height":  1123
                                                             },
                                       "print_size":  "210mm x 297mm",
                                       "safe_margin_mm":  14
                                   },
                          "colors":  {
                                         "paper":  "#F4F1E8",
                                         "paper_soft":  "#FCFAF4",
                                         "ink":  "#111111",
                                         "muted":  "#595959",
                                         "line":  "#BEB7A9",
                                         "card":  "#FFFEFA",
                                         "accent":  "#111111",
                                         "accent_dark":  "#000000",
                                         "accent_soft":  "#EBE7DC",
                                         "warning":  "#8A5A18"
                                     },
                          "typography":  {
                                             "display":  "Noto Serif SC, Songti SC, SimSun, Georgia, serif",
                                             "body":  "Inter, Noto Sans SC, Microsoft YaHei, Arial, sans-serif",
                                             "mono":  "JetBrains Mono, Consolas, monospace"
                                         },
                          "shapes":  {
                                         "card_border":  "1.5px solid #111111",
                                         "card_radius":  "2px",
                                         "callout_radius":  "2px"
                                     }
                      },
    "component_showroom_sections":  [
                                        "page_shell",
                                        "identity_system",
                                        "cards_and_metrics",
                                        "structured_tables",
                                        "flow_components",
                                        "comparison_and_money",
                                        "evidence_and_action",
                                        "ledger_and_profile",
                                        "connector_canvas",
                                        "chart_components"
                                    ],
    "component_catalog":  [
                              "page_header",
                              "identity_footer",
                              "cover_identity",
                              "card",
                              "callout",
                              "metric",
                              "tag_row",
                              "timeline",
                              "pipeline",
                              "mini_table",
                              "focus_matrix",
                              "position_board",
                              "ledger",
                              "amount_grid",
                              "proof_grid",
                              "heatmap",
                              "action_board",
                              "connector_canvas",
                              "profile_card",
                              "bar_chart",
                              "stacked_bar_chart",
                              "donut_chart",
                              "waterfall_chart",
                              "risk_quadrant",
                              "score_gauge",
                              "calendar_strip"
                          ],
    "identity_system":  {
                            "purpose":  "Editorial report identity system for individual lawyer, law firm team, or corporate-style firm.",
                            "identity_types":  [
                                                   "solo_lawyer",
                                                   "law_firm_team",
                                                   "corporate_firm"
                                               ],
                            "empty_state_policy":  {
                                                       "avatar_url":  "Use text mark or initials.",
                                                       "logo_url":  "Use display_name as brand mark.",
                                                       "bio_short":  "Omit biography area and enlarge practice/contact modules.",
                                                       "team_members":  "Hide member-role grid and keep lead lawyer/team positioning.",
                                                       "qr_code_url":  "Hide QR slot; do not render an empty placeholder."
                                                   },
                            "rendering_slots":  [
                                                    "cover_identity",
                                                    "persistent_footer_identity",
                                                    "profile_card"
                                                ]
                        },
    "agent_guidance":  {
                           "allowed_to_choose":  [
                                                     "approved component",
                                                     "page title",
                                                     "short explanatory copy",
                                                     "semantic grouping of structured facts, evidence, issues, amounts, and next actions",
                                                     "visual intent that maps to a known component"
                                                 ],
                           "not_allowed_to_generate":  [
                                                           "external scripts",
                                                           "arbitrary CSS tokens",
                                                           "unbounded HTML",
                                                           "new unrelated visual style",
                                                           "overlong paragraphs",
                                                           "absolute-positioned div arrows"
                                                       ]
                       },
    "renderer_constraints":  {
                                 "escape_text":  true,
                                 "allow_external_scripts":  false,
                                 "print_ready":  true,
                                 "page_overflow_policy":  "split page or condense block",
                                 "agent_html_policy":  "Agent outputs structured page plan only; renderer owns final HTML"
                             }
}
